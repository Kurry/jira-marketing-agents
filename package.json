{
  "name": "jira-ai-growth-rovo-agents",
  "version": "0.1.0",
  "description": "Forge/Rovo agents for an AI Growth Ops Jira ticketing system.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:integration:mock": "vitest run tests/integration/provision-mock.test.ts",
    "test:readiness:jira": "AIGO_INSTANCE_CONFIG=instances/aigo.example.json node scripts/aigo-project-readiness.cjs",
    "test:smoke:jira": "bash scripts/live-jira-smoke.sh",
    "test:watch": "vitest",
    "seed:render": "node scripts/render-seed.cjs",
    "render:automation": "node scripts/render-automation-rules.cjs",
    "provision:instance": "node scripts/provision-instance.cjs",
    "provision:jira": "node scripts/provision-jira.cjs",
    "provision:jira:dry": "node scripts/provision-jira.cjs --dry-run",
    "provision:seeds": "node scripts/provision-seeds.cjs",
    "provision:automation": "node scripts/provision-automation.cjs",
    "provision:all": "node scripts/provision-all.cjs",
    "provision:filters": "node scripts/provision-filters.cjs",
    "provision:dashboards": "node scripts/provision-dashboards.cjs",
    "check:rovo": "node scripts/check-rovo-visibility.cjs",
    "audit": "node scripts/audit/run-all.mjs",
    "infra:plan": "node scripts/infra/plan.mjs",
    "infra:apply": "node scripts/infra/apply.mjs",
    "infra:verify": "node scripts/verify/run-all.mjs",
    "infra:render": "node scripts/infra/render-all.mjs",
    "test:safety": "vitest run tests/safety",
    "rovo:invoke-all": "node scripts/invoke/run-all.mjs",
    "forge:deploy": "forge deploy -e development",
    "forge:install": "forge install --upgrade -e development -p jira --site myhealthcaresite.atlassian.net --confirm-scopes",
    "forge:lint": "forge lint",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@forge/api": "latest",
    "jira.js": "^5.3.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "nock": "^14.0.15",
    "typescript": "latest",
    "vitest": "latest",
    "yaml": "^2.9.0"
  }
}
