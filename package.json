{
  "name": "jira-ai-growth-rovo-agents",
  "version": "0.1.0",
  "description": "Forge/Rovo agents for an AI Growth Ops Jira ticketing system.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
